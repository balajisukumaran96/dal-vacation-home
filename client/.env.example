# AWS API Gateway endpoint
VITE_BASE_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/Prod

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# AWS Cognito Configuration
VITE_AWS_REGION=us-east-1
VITE_AWS_USER_POOL_ID=your-user-pool-id
VITE_AWS_USER_POOL_WEB_CLIENT_ID=your-web-client-id
VITE_AWS_IDENTITY_POOL_ID=your-identity-pool-id

# AWS S3 Configuration for Photo Upload
VITE_S3_BUCKET=your-s3-bucket-name
